# =============================================================================
# mem0 deployment environment variables.
# Copy to `.env` and fill in real values before `docker compose up`.
# Lines marked REQUIRED must be set or the compose file will refuse to start.
# =============================================================================

# --- PostgreSQL (used by pgvector for memory storage) ---
# Service name when running under the sample compose; otherwise your host.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Database used by pgvector for memory storage.
POSTGRES_DB=postgres
POSTGRES_USER=postgres
# REQUIRED — the sample compose refuses to start without it.
POSTGRES_PASSWORD=
# pgvector collection name for memories.
POSTGRES_COLLECTION_NAME=memories

# --- mem0 application database (created by init/init-db.sh on first boot) ---
# Separate DB used for users / api_keys / auth.
APP_DB_NAME=mem0_app

# --- Docker networking ---
# Compose network name used by the sample stack and standalone migration runner.
MEM0_NETWORK_NAME=mem0_network

# --- History ---
# SQLite path inside the mem0-server container for chat history.
HISTORY_DB_PATH=/app/history/history.db

# --- Auth ---
# REQUIRED — random string of 32+ characters used to sign JWTs.
JWT_SECRET=
# Set to true to disable auth entirely (development only).
AUTH_DISABLED=false
# Optional — set to skip the dashboard setup wizard on a fresh deploy.
# Works because mem0 bootstraps this admin key when zero users exist.
ADMIN_API_KEY=

# --- Telemetry ---
# mem0's PostHog telemetry is ON by default. Set to false to opt out.
MEM0_TELEMETRY=true

# --- LLM provider keys (at least one is expected by mem0) ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# --- Dashboard <-> Server URLs (the three "must match" vars) ---
# Server-side CORS origin — MUST match your dashboard's external URL.
DASHBOARD_URL=http://localhost:3000
# What the BROWSER sees — your API's externally-reachable URL.
NEXT_PUBLIC_API_URL=http://localhost:8888
# Dashboard -> API server-to-server call. Under the sample compose this is the
# service DNS name; when hosting separately, set it to the API URL reachable
# from the dashboard host.
API_INTERNAL_URL=http://mem0-server:8000

# --- Dashboard branding ---
NEXT_PUBLIC_INSTANCE_NAME=Mem0
